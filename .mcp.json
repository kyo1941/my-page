{
  "mcpServers": {
    "my-page-blog": {
      "command": "node",
      "args": ["mcp/dist/index.js"],
      "env": {
        "API_BASE_URL": "${API_BASE_URL:-http://localhost:8080}",
        "ORIGIN": "${ORIGIN:-http://localhost:3000}",
        "ADMIN_USERNAME": "${ADMIN_USERNAME}",
        "ADMIN_PASSWORD": "${ADMIN_PASSWORD}"
      }
    }
  }
}
