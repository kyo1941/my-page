# ============================================================
# 開発環境用 環境変数テンプレート
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# ============================================================

# ---- MySQL (Docker) ----------------------------------------

# MySQLのrootパスワード
# 条件: 12文字以上、英大文字・小文字・数字・記号を含むこと
# 生成例: openssl rand -base64 16
MYSQL_ROOT_PASSWORD=YOUR_MYSQL_ROOT_PASSWORD

# アプリ用ユーザーのパスワード（DB_PASSWORDと同じ値を設定）
# 条件: 12文字以上、英大文字・小文字・数字・記号を含むこと
MYSQL_PASSWORD=YOUR_MYSQL_PASSWORD

MYSQL_DATABASE=kyo1941_portfolio_db
MYSQL_USER=kyo1941_portfolio_user

# ---- バックエンド (Ktor) ------------------------------------

DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_PASSWORD=YOUR_MYSQL_PASSWORD  # MYSQL_PASSWORDと同じ値
DB_USER=kyo1941_portfolio_user
DB_MAX_POOL_SIZE=10

# 実行環境 (dev / production)
KTOR_ENV=dev

# JWT認証シークレット
# 条件: 256bit以上のランダム文字列
# 生成例: openssl rand -base64 32
# ※ フロントエンドの JWT_SECRET と同一の値を設定すること
JWT_SECRET=YOUR_JWT_SECRET

# 管理者アカウント
# ADMIN_PASSWORDの条件: 16文字以上、英大文字・小文字・数字・記号を含むこと
ADMIN_USERNAME=YOUR_ADMIN_USERNAME
ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD

# Cloudflare Turnstile（スパム対策）
# 開発環境ではCloudflare公式のテストキーを使用
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Resend（メール送信）
RESEND_API_KEY=YOUR_RESEND_API_KEY
# 送信元メールアドレス（開発環境はResendのデフォルト、本番はcontact@kyo1941.com）
RESEND_FROM_EMAIL=onboarding@resend.dev
# お問い合わせの送信先メールアドレス
RECIPIENT_EMAIL=YOUR_RECIPIENT_EMAIL

# ---- docker-compose.prod.yml ローカル本番テスト用 ----------
# (docker-compose up では不要)

NEXT_PUBLIC_TURNSTILE_SITE_KEY=YOUR_TURNSTILE_SITE_KEY
JWT_ISSUER=http://localhost:8080/
JWT_AUDIENCE=my-page-users
