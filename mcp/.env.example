# 接続先バックエンドの URL
# ローカル: http://localhost:8080
# 本番:     https://<app>.onrender.com
API_BASE_URL=http://localhost:8080

# CSRF 保護用の Origin ヘッダー（バックエンドの CORS_ALLOWED_ORIGINS と一致させる）
# ローカル: http://localhost:3000
# 本番:     https://<your-vercel-domain>
ORIGIN=http://localhost:3000

# 管理者アカウント（バックエンドの ADMIN_USERNAME / ADMIN_PASSWORD と同じ値）
ADMIN_USERNAME=
ADMIN_PASSWORD=
