# 読み取り・ログイン先のバックエンド URL
# ローカル: http://localhost:8080
# 本番:     https://<app>.up.railway.app
BACKEND_URL=http://localhost:8080

# 変更系(作成/更新/削除)を通すフロントエンド URL。
# フロントの /api/admin プロキシ経由にすることで revalidatePath が発火し、
# 公開ブログページのキャッシュが更新される。CSRF 用 Origin にもこの値を使う
# (バックエンドの CORS_ALLOWED_ORIGINS と一致させる)。
# ローカル: http://localhost:3000
# 本番:     https://<your-frontend-domain>
FRONTEND_URL=http://localhost:3000

# 管理者アカウント（バックエンドの ADMIN_USERNAME / ADMIN_PASSWORD と同じ値）
ADMIN_USERNAME=
ADMIN_PASSWORD=

# 補足: ソースを編集したら `npm run build` で dist を更新すること。
# (.mcp.json は dist が無い場合のみ自動ビルドする)
