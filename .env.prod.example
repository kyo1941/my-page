# ============================================================
# 本番環境用 環境変数リファレンス
# このファイルはコミット対象です（プレースホルダーのみ記載）
#
# 実際の値は各サービスのダッシュボードで設定してください:
#   - バックエンド: Railway ダッシュボード
#   - フロントエンド: Vercel ダッシュボード
#   - データベース: Aiven ダッシュボード（接続情報を取得）
# ============================================================

# ============================================================
# [Railway] バックエンド環境変数
# Railway Dashboard > my-page-backend > Variables
# ============================================================

# ---- データベース (Aiven MySQL) ----------------------------

DB_DRIVER=com.mysql.cj.jdbc.Driver

# AivenのMySQL接続文字列（SSL必須）
# Aiven Dashboard > サービス > Overview > Connection information から取得
# 形式: jdbc:mysql://<host>:<port>/<database>?sslMode=REQUIRED
DB_URL=jdbc:mysql://YOUR_AIVEN_HOST:YOUR_AIVEN_PORT/YOUR_DATABASE?sslMode=REQUIRED

# AivenのMySQLユーザー情報
DB_USER=YOUR_AIVEN_DB_USER

# AivenのMySQLパスワード
# 条件: Aivenが自動生成（変更する場合は12文字以上、英大文字・小文字・数字・記号を含むこと）
DB_PASSWORD=YOUR_AIVEN_DB_PASSWORD

DB_MAX_POOL_SIZE=5

# ---- JWT認証 -----------------------------------------------

# 条件: 256bit以上のランダム文字列（開発環境と異なる値を推奨）
# 生成例: openssl rand -base64 32
# ※ Vercelの JWT_SECRET と必ず同一の値を設定すること
JWT_SECRET=YOUR_JWT_SECRET

# 本番バックエンドのURL（RailwayのサービスURLに合わせる）
# 例: https://my-page-backend.up.railway.app/
JWT_ISSUER=https://YOUR_RAILWAY_SERVICE.up.railway.app/
JWT_AUDIENCE=my-page-users

# ---- 管理者アカウント --------------------------------------

ADMIN_USERNAME=YOUR_ADMIN_USERNAME

# 条件: 16文字以上、英大文字・小文字・数字・記号を含むこと（開発環境と異なる値を推奨）
# 生成例: openssl rand -base64 16
ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD

# ---- 外部サービス ------------------------------------------

# Cloudflare Turnstile シークレットキー（Turnstile Dashboard > サイト > Secret key）
TURNSTILE_SECRET_KEY=YOUR_TURNSTILE_SECRET_KEY

# Resend APIキー（Resend Dashboard > API Keys）
RESEND_API_KEY=YOUR_RESEND_API_KEY

# Resend 送信元メールアドレス
RESEND_FROM_EMAIL=contact@kyo1941.com

# CORSで許可するオリジン（フロントエンドのVercelドメイン）
CORS_ALLOWED_ORIGINS=https://kyo1941.com

KTOR_ENV=production

# ============================================================
# [Vercel] フロントエンド環境変数
# Vercel Dashboard > my-page > Settings > Environment Variables
# Environment: Production のみに設定すること
# ============================================================

# RailwayのバックエンドサービスURL
NEXT_PUBLIC_API_BASE_URL=https://YOUR_RAILWAY_SERVICE.up.railway.app

# Cloudflare Turnstile サイトキー（公開可）
NEXT_PUBLIC_TURNSTILE_SITE_KEY=YOUR_TURNSTILE_SITE_KEY

# JWT検証設定（Railwayの JWT_SECRET / JWT_ISSUER / JWT_AUDIENCE と同一の値を設定すること）
JWT_SECRET=YOUR_JWT_SECRET
JWT_ISSUER=https://YOUR_RAILWAY_SERVICE.up.railway.app/
JWT_AUDIENCE=my-page-users
