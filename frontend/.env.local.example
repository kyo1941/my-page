# ============================================================
# フロントエンド開発環境用 環境変数テンプレート
# このファイルをコピーして .env.local を作成してください
# cp .env.local.example .env.local
# ============================================================

# バックエンドAPIのURL（開発時はdocker-compose起動後のバックエンド）
NEXT_PUBLIC_API_BASE_URL="http://localhost:8080"

# Cloudflare Turnstile サイトキー（公開可）
# 開発環境ではCloudflare公式のテストキーを使用
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"

# JWT検証設定（バックエンドの application.yaml と同一の値を設定すること）
# JWT_SECRETの条件: 256bit以上のランダム文字列
# 生成例: openssl rand -base64 32
JWT_SECRET="YOUR_JWT_SECRET"
JWT_ISSUER="http://localhost:8080/"
JWT_AUDIENCE="my-page-users"
